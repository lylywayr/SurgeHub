{{{HTTPDNS拦截器}}}^https:\/\/ucdc\d?-upaas\.uc\.cn\/api\/v\d\/dns_query\? data-type=text data="{}" status-code=200 header="Content-Type:application/json"
{{{HTTPDNS拦截器}}}^https:\/\/gw-cn\.jiaoliuqu\.com\/taqu-im-broadcast-srv\/v\d\/Comet\/get\? data-type=text data="{}" status-code=200 header="Content-Type:application/json"

[MITM]
# HTTPDNS拦截器
{{{HTTPDNS拦截器}}}hostname = %APPEND% appconf.mail.163.com, msglb.91160.com, ucdc2-upaas.uc.cn, gw-cn.jiaoliuqu.com
# 广告平台拦截器
{{{广告平台拦截器}}}hostname = %APPEND% video-dsp.pddpic.com, t-dsp.pinduoduo.com, images.pinduoduo.com
# 菜鸟去广告
{{{菜鸟去广告}}}hostname = %APPEND% netflow-mtop.cainiao.com, nbcps-mtop.cainiao.com, cn-acs.m.cainiao.com, e2e-mtop.cainiao.com, longquan-mtop.cainiao.com
# 微信外部链接解锁
{{{微信外部链接解锁}}}hostname = %APPEND% weixin110.qq.com, security.wechat.com

[Script]
# 微信外部链接解锁
{{{微信外部链接解锁}}}微信外部链接解锁 = type=http-response, pattern=^https\:\/\/(weixin110\.qq|security.wechat)\.com\/cgi-bin\/mmspamsupport-bin\/newredirectconfirmcgi\?, script-path=https://kelee.one/Resource/JavaScript/Weixin/Weixin_external_links_unlock.js, requires-body=true
