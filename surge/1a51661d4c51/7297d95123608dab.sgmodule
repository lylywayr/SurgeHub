#!name=Google自动翻页
#!desc=广告屏蔽：Google自动翻页

[Script]
endlessgoogle = type=http-response, pattern=^https?:\/\/www\.google\..*\/search, script-path=https://raw.githubusercontent.com/ddgksf2013/Scripts/master/endlessgoogle.js, requires-body=true, max-size=-1, timeout=60

[MITM]
hostname = %APPEND% www.google.*
