[Rule]
# 12306去广告
{{{12306去广告}}}DOMAIN,ad.12306.cn,DIRECT
# 滴滴出行去广告
{{{滴滴出行去广告}}}DOMAIN,gwp.xiaojukeji.com,REJECT
{{{滴滴出行去广告}}}AND,((IP-ASN,45090,no-resolve),(DEST-PORT,25641),(PROTOCOL,TCP)),REJECT
{{{滴滴出行去广告}}}AND,((IP-ASN,55990,no-resolve),(DEST-PORT,25641),(PROTOCOL,TCP)),REJECT
{{{滴滴出行去广告}}}AND,((IP-ASN,63646,no-resolve),(DEST-PORT,25641),(PROTOCOL,TCP)),REJECT
# 高德地图去广告
{{{高德地图去广告}}}DOMAIN,amap-aos-info-nogw.amap.com,REJECT
{{{高德地图去广告}}}DOMAIN,free-aos-cdn-image.amap.com,REJECT
{{{高德地图去广告}}}DOMAIN-SUFFIX,v.smtcdns.com,REJECT
# 航旅纵横去广告
{{{航旅纵横去广告}}}URL-REGEX,"^http?:\/\/(discardrp|startup)\.umetrip\.com\/gateway\/api\/umetrip\/native",REJECT
# 马蜂窝去广告
{{{马蜂窝去广告}}}DOMAIN,advert.mafengwo.cn,REJECT

