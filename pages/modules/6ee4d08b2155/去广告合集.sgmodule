{{{网易云音乐去广告}}}评论区、热推、有话想说、分享一下、歌曲下的祝福等小提示 = type=http-response, pattern=^https?:\/\/interface\d?\.music\.163\.com\/eapi\/(?:batch|v2\/resource\/comment\/floor\/get), script-path=https://kelee.one/Resource/JavaScript/NeteaseCloudMusic/NeteaseCloudMusic_remove_ads.js, requires-body=true, binary-body-mode=true, timeout=20
{{{网易云音乐去广告}}}推荐、home、主页 = type=http-response, pattern=^https?:\/\/interface\d?\.music\.163\.com\/eapi\/(?:homepage\/block\/page|link\/page\/rcmd\/(?:block\/resource\/multi\/refresh|resource\/show)), script-path=https://kelee.one/Resource/JavaScript/NeteaseCloudMusic/NeteaseCloudMusic_remove_ads.js, requires-body=true, binary-body-mode=true, timeout=20, argument="[{{{隐藏首页_问候语}}},{{{隐藏首页_排行榜}}},{{{隐藏首页_每日推荐}}},{{{隐藏首页_推荐歌单}}},{{{隐藏首页_最近常听}}},{{{隐藏首页_雷达歌单}}},{{{隐藏首页_音乐合伙人}}},{{{隐藏首页_推荐专属歌单}}},{{{隐藏首页_你的专属歌单}}}]"
